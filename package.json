{
	"name": "@bessonovs/set-project-references",
	"description": "Set project references for TypeScript",
	"keywords": [
		"TypeScript",
		"Project References",
		"monorepo",
		"pnpm"
	],
	"version": "0.0.12",
	"author": "Anton Bessonov",
	"main": "./dist/index.js",
	"license": "MIT",
	"repository": "Bessonov/set-project-references",
	"sideEffects": false,
	"scripts": {
		"start": "ts-node ./src/index.ts",
		"debug": "node --inspect-brk -r ts-node/register ./src/index.ts",
		"build": "tsc",
		"cli": "node ./dist/index.js",
		"lint": "eslint .",
		"format": "dprint check",
		"format:fix": "dprint fmt",
		"test": "jest --coverage",
		"precommit": "pnpm run format && pnpm run test && pnpm run lint && pnpm run build",
		"update": "pnpm update --interactive --latest",
		"update:pnpm": "corepack use 'pnpm@*'",
		"update:node": "fnm install --lts | sed 's/.*\\(v[0-9.]\\+\\)$/\\1/g' | tail -n 1 > .nvmrc"
	},
	"bin": {
		"set-project-references": "./dist/index.js"
	},
	"dependencies": {
		"commander": "14.0.3",
		"comment-json": "4.5.1",
		"detect-indent": "7.0.2",
		"glob": "13.0.6",
		"js-yaml": "4.1.1",
		"lodash": "4.17.23"
	},
	"devDependencies": {
		"@types/glob": "9.0.0",
		"@types/jest": "30.0.0",
		"@types/js-yaml": "4.0.9",
		"@types/lodash": "4.17.24",
		"@types/node": "25.3.3",
		"dprint": "0.50.2",
		"eslint": "9.37.0",
		"eslint-plugin-import": "2.32.0",
		"jest": "30.2.0",
		"ts-jest": "29.4.6",
		"ts-node": "10.9.2",
		"typescript": "5.9.3",
		"typescript-eslint": "8.46.1"
	},
	"publishConfig": {
		"access": "public"
	},
	"packageManager": "pnpm@10.30.3+sha512.c961d1e0a2d8e354ecaa5166b822516668b7f44cb5bd95122d590dd81922f606f5473b6d23ec4a5be05e7fcd18e8488d47d978bbe981872f1145d06e9a740017"
}
